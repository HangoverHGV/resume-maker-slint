import { SideBar } from "components/side_bar.slint";
import { PersonalPage } from "./pages/personal.slint";
import { PersonalData } from "models/personal_info.slint";
import { EducationData } from "./models/education_data.slint";
import { EducationPage } from "./pages/education.slint";

export component AppWindow inherits Window {
    title: "Resume Maker";
    maximized: false;

    preferred-width: 1300px;
    preferred-height: 800px;

    in-out property <[string]> resumes-list;

    in-out property <PersonalData> personal-data;
    in-out property <EducationData> education-data;

    callback menu-item-clicked(string, string); //(resume_name, action_type)
    callback save-personal-info(PersonalData);
    callback save-education-info(EducationData);
    callback clear-all-fields();

    MenuBar {
        Menu {
            title: "Open";
            MenuItem {
                title: "Add";
                activated => {
                    clear-all-fields();
                }
            }
            MenuSeparator {}
            for resume in root.resumes-list: Menu {
                title: resume;
                if resume != "Add":MenuItem {
                    title: "Edit";
                    activated => {
                        menu-item-clicked(resume, "edit");
                    }
                }

                if resume != "Add": MenuItem {
                    title: "Delete";

                    activated => {
                        menu-item-clicked(resume, "delete");
                    }
                }
            }
        }
    }

    HorizontalLayout {

        side-bar := SideBar {
            accessible-role: navigation;
            accessible-label: "Sidebar";
            model: [
                "Personal Info",
                "Education Info",
            ];
        }

        VerticalLayout {
            accessible-role: main;
            accessible-label: "Content";
            if (side-bar.current-item == 0): PersonalPage {

                personal_data: personal-data;

                save-personal-info(personal-data) => {
                    root.save-personal-info(personal-data);
                }
            }

            if (side-bar.current-item == 1): EducationPage{
                education_data: education-data;
                save-education-info(education-data) => {
                    root.save-education-info(education-data);
                }
            }
        }
    }
}
