import { SideBar } from "components/side_bar.slint";
import { PersonalPage } from "./pages/personal.slint";


export component AppWindow inherits Window {
    title: "Resume Maker";
    maximized: false;

    preferred-width: 1000px;
    preferred-height: 700px;

    in-out property <[string]> resumes-list;

    callback save-personal-info(string, string, string, string, string, string, string, string, string);

    MenuBar {
        Menu {
            title: "Open";
            for resume in root.resumes-list: Menu {
                title: resume;
                if resume != "Add":MenuItem {
                    title: "Edit";
                }

                if resume != "Add": MenuItem {
                    title: "Delete";
                }
            }
        }
    }

    HorizontalLayout {

        side-bar := SideBar {
            accessible-role: navigation;
            accessible-label: "Sidebar";
            model: [
                "Personal Info",
            ];
        }

        VerticalLayout {
            accessible-role: main;
            accessible-label: "Content";
            if (side-bar.current-item == 0): PersonalPage {
                save-personal-info(cv_name, name, job_title, email, phone, location, linkedin, github, website) => {
                    root.save-personal-info(cv_name, name, job_title, email, phone, location, linkedin, github, website);
                }
            }
        }
    }
}
